# tokenmaxxer config — copy to .env and edit.  `install.sh` sources this.
# Inline env vars (e.g. for the curl|bash one-liner) override these.
# Budget/thresholds can also be changed later from the menu → Configure.

# LiteLLM gateway root
TOKENMAXXER_BASE_URL=https://ai.celonis.dev

# Monthly budget in USD (gateway virtual keys usually can't read max_budget)
TOKENMAXXER_BUDGET=200

# Color thresholds, as % of budget
TOKENMAXXER_WARN=75
TOKENMAXXER_CRIT=90

# SwiftBar refresh interval (e.g. 30s, 60s, 5m). Encoded into the plugin filename.
TOKENMAXXER_INTERVAL=60s

# LiteLLM virtual key. If set, install.sh stores it in the macOS Keychain.
# Leave blank to be prompted, or to keep an existing Keychain entry. NEVER commit a real key.
TOKENMAXXER_API_KEY=

# GitHub user — fills the install one-liner URL and the plugin's About link.
GITHUB_USER=REPLACE_ME
